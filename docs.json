{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Pandabase",
  "colors": {
    "primary": "#0a8237",
    "light": "#07C983",
    "dark": "#0b7031"
  },
  "logo": {
    "light": "/logo/dark.png",
    "dark": "/logo/dark.png"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "global": {
      "anchors": []
    },
    "tabs": [
      {
        "icon": "book-bookmark",
        "tab": "The Guide",
        "groups": [
          {
            "icon": "book-blank",
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "pricing"
            ]
          },
          {
            "icon": "book",
            "group": "Guides",
            "pages": [
              {
                "expanded": true,
                "icon": "user",
                "group": "Your Account",
                "pages": [
                  "guides/accounts"
                ]
              },
              {
                "expanded": true,
                "icon": "store",
                "group": "Your Store",
                "pages": [
                  "guides/analytics",
                  "guides/payments",
                  "guides/payouts"
                ]
              }
            ]
          }
        ]
      },
      {
        "icon": "brackets-curly",
        "tab": "Developers",
        "groups": [
          {
            "icon": "book-open-cover",
            "group": "Learn",
            "pages": [
              "developers/learn/lifecycle",
              "developers/learn/dynamic-payments",
              "developers/learn/hosted-checkout",
              "developers/learn/subscriptions",
              "developers/learn/api-tokens"
            ]
          },
          {
            "icon": "code",
            "group": "WebSDK (Private Preview)",
            "pages": [
              "developers/websdk/getting-started"
            ]
          },
          {
            "icon": "webhook",
            "group": "Webhooks",
            "pages": [
              "developers/webhooks/overview",
              "developers/webhooks/events"
            ]
          }
        ]
      },
      {
        "icon": "terminal",
        "tab": "API reference",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "developers/introduction",
              "developers/pagination",
              "developers/rate-limits",
              "developers/responses",
              "developers/changelog",
              {
                "expanded": true,
                "group": "Core Resources",
                "openapi": "developers/openapi.json"
              },
              {
                "expanded": true,
                "group": "Storefront",
                "openapi": "developers/storefront-openapi.json"
              },
              {
                "expanded": true,
                "group": "Billing",
                "openapi": "developers/checkout-openapi.json"
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@pandabase.io"
      },
      {
        "label": "Customer Portal",
        "href": "https://mypandabase.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Merchant Portal",
      "href": "https://merchant.pandabase.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pandabasehq",
      "github": "https://github.com/pandabase",
      "discord": "https://discord.gg/pandabase"
    }
  }
