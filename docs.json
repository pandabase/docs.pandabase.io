{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Pandabase",
  "colors": {
    "primary": "#0a8237",
    "light": "#07C983",
    "dark": "#0b7031"
  },
  "logo": {
    "light": "/logo/dark.png",
    "dark": "/logo/dark.png"
  },
  "icons": {
    "library": "fontawesome"
  },
  "fonts": {
    "heading": { "family": "Sora" },
    "body": { "family": "Inter" }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "products": [
      {
        "product": "For Merchants",
        "icon": "shop",
        "tabs": [
          {
            "tab": "Getting started",
            "groups": [
              {
                "group": "Quickstart",
                "pages": ["index", "quickstart", "pricing"]
              }
            ]
          },
          {
            "tab": "Manage your store",
            "groups": [
              {
                "group": "Analytics",
                "pages": ["merchants/store/analytics"]
              },
              {
                "group": "Manage products",
                "pages": []
              },
              {
                "group": "Manage payments",
                "pages": ["merchants/store/payments"]
              },
              {
                "group": "Manage payouts",
                "pages": ["merchants/store/payouts"]
              }
            ]
          },
          {
            "tab": "Your account",
            "groups": [
              {
                "group": "Managing your account",
                "pages": ["merchants/account/index"]
              }
            ]
          },
          {
            "tab": "Trust and safety",
            "groups": [
              {
                "group": "Overview",
                "pages": ["merchants/trust-and-safety/prohibited-businesses"]
              }
            ]
          }
        ]
      },
      {
        "product": "For Developers",
        "icon": "square-terminal",
        "tabs": [
          {
            "tab": "Documentation",
            "groups": [
              {
                "icon": "book-open-cover",
                "group": "Learn",
                "pages": [
                  "developers/learn/lifecycle",
                  "developers/learn/dynamic-payments",
                  "developers/learn/hosted-checkout",
                  "developers/learn/subscriptions",
                  "developers/learn/api-tokens"
                ]
              },
              {
                "icon": "code",
                "group": "WebSDK (Private Preview)",
                "pages": ["developers/websdk/getting-started"]
              },
              {
                "icon": "webhook",
                "group": "Webhooks",
                "pages": [
                  "developers/webhooks/overview",
                  "developers/webhooks/events",
                  "developers/webhooks/migrate-signatures"
                ]
              },
              {
                "icon": "brackets-curly",
                "group": "SDKs",
                "pages": ["developers/sdks/typescript", "developers/sdks/go"]
              },
              {
                "group": "Connected accounts",
                "pages": ["developers/connected-accounts/quickstart"]
              },
              {
                "group": "Changes",
                "pages": ["developers/changelog"]
              }
            ]
          },
          {
            "tab": "API (V2) Reference",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "developers/api/v2/introduction",
                  "developers/api/v2/pagination",
                  "developers/api/v2/rate-limits",
                  "developers/api/v2/responses",
                  {
                    "expanded": true,
                    "group": "Core Resources",
                    "openapi": "developers/api/v2/schemas/core-openapi.json"
                  },
                  {
                    "expanded": true,
                    "group": "Storefront",
                    "openapi": "developers/api/v2/schemas/storefront-openapi.json"
                  },
                  {
                    "expanded": true,
                    "group": "Billing",
                    "openapi": "developers/api/v2/schemas/checkout-openapi.json"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@pandabase.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Merchant Portal",
      "href": "https://merchant.pandabase.io"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pandabasehq",
      "github": "https://github.com/pandabase",
      "discord": "https://discord.gg/pandabase"
    }
  }
}
